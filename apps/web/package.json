{
  "name": "@ffcodec/web",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "FFCodec Lab — Pure frontend FFmpeg encoding command builder (Web)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build && node ../../scripts/build-sites.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ffmpeg": "npx tsx ../../scripts/ffmpeg-smoke-test.ts",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "audit:catalog": "npx tsx ../../scripts/validate-catalog.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run audit:catalog && npm run build"
  },
  "dependencies": {
    "@ffcodec/catalog": "workspace:*",
    "@ffcodec/domain": "workspace:*",
    "@ffcodec/platform-api": "workspace:*",
    "@ffcodec/workbench": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  }
}
