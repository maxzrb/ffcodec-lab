{
  "name": "@ffcodec/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "FFCodec Lab — Electron desktop application",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=&& electron-vite dev",
    "build": "set ELECTRON_RUN_AS_NODE=&& electron-vite build",
    "preview": "set ELECTRON_RUN_AS_NODE=&& electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@ffcodec/command-plan": "workspace:*",
    "@ffcodec/platform-api": "workspace:*",
    "@ffcodec/workbench": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^35.1.2",
    "electron-vite": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
